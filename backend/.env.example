# Supabase — Transaction mode pooler (runtime queries)
DATABASE_URL=postgresql://user:password@host:6543/db

# Supabase — Direct connection (Alembic migrations only)
DATABASE_URL_DIRECT=postgresql://user:password@host:5432/db

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# File storage (local for now)
FILE_STORAGE_PATH=archive

# CORS — add Streamlit URL when deploying
BACKEND_CORS_ORIGINS=["http://localhost:8501","http://localhost:8502"]
